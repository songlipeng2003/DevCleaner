        {"path": "~/Library/Application Support/JetBrains", "description": "JetBrains 配置 (macOS)", "strategy": "safe"},
        {"path": "%APPDATA%\\JetBrains", "description": "JetBrains 配置 (Windows)", "strategy": "safe"},
