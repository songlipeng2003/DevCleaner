    {
      "id": "vscode",
      "name": "VS Code",
      "description": "Visual Studio Code 缓存清理",
      "platforms": ["darwin", "linux", "windows"],
      "cleanItems": [
        {
          "id": "cache",
          "name": "Cache",
          "description": "缓存",
          "paths": [
            {"path": "~/.cache/VSCode", "description": "VS Code 缓存 (Linux)", "strategy": "direct"},
            {"path": "~/Library/Caches/Code", "description": "VS Code 缓存 (macOS)", "strategy": "direct"},
            {"path": "%LOCALAPPDATA%\\VSCode", "description": "VS Code 缓存 (Windows)", "strategy": "direct"}
          ]
        },
        {
          "id": "gpu-cache",
          "name": "GPUCache",
          "description": "GPU 缓存",
          "paths": [
            {"path": "~/.config/Code/GPUCache", "description": "GPU 缓存 (Linux)", "strategy": "direct"},
            {"path": "~/Library/Application Support/Code/GPUCache", "description": "GPU 缓存 (macOS)", "strategy": "direct"},
            {"path": "%APPDATA%\\Code\\GPUCache", "description": "GPU 缓存 (Windows)", "strategy": "direct"}
          ]
        },
        {
          "id": "logs",
          "name": "Logs",
          "description": "日志文件",
          "paths": [
            {"path": "~/.config/Code/logs", "description": "日志 (Linux)", "strategy": "direct"},
            {"path": "~/Library/Application Support/Code/logs", "description": "日志 (macOS)", "strategy": "direct"},
            {"path": "%APPDATA%\\Code\\logs", "description": "日志 (Windows)", "strategy": "direct"}
          ]
        },
        {
          "id": "indexeddb",
          "name": "IndexedDB",
          "description": "数据库",
          "paths": [
            {"path": "~/.config/Code/CachedData", "description": "缓存数据 (Linux)", "strategy": "direct"},
            {"path": "~/Library/Application Support/Code/CachedData", "description": "缓存数据 (macOS)", "strategy": "direct"},
            {"path": "%APPDATA%\\Code\\CachedData", "description": "缓存数据 (Windows)", "strategy": "direct"}
          ]
        },
        {
          "id": "cached-extensions",
          "name": "CachedExtensions",
          "description": "扩展缓存",
          "paths": [
            {"path": "~/.config/Code/CachedExtensions", "description": "扩展缓存 (Linux)", "strategy": "direct"},
            {"path": "~/Library/Application Support/Code/CachedExtensions", "description": "扩展缓存 (macOS)", "strategy": "direct"},
            {"path": "%APPDATA%\\Code\\CachedExtensions", "description": "扩展缓存 (Windows)", "strategy": "direct"}
          ]
        },
        {
          "id": "global-storage",
          "name": "GlobalStorage",
          "description": "全局存储",
          "paths": [
            {"path": "~/.config/Code/User/globalStorage", "description": "全局存储 (Linux)", "strategy": "safe"},
            {"path": "~/Library/Application Support/Code/User/globalStorage", "description": "全局存储 (macOS)", "strategy": "safe"},
            {"path": "%APPDATA%\\Code\\User\\globalStorage", "description": "全局存储 (Windows)", "strategy": "safe"}
